# Docker Compose - variables de entorno
# Copia este archivo a .env y ajusta los valores.
# NUNCA commitees el archivo .env real.

# Puerto interno donde escucha el nginx del proyecto.
# Caddy (proxy inverso con HTTPS) va delante en :80/:443 y reenvia a este puerto.
APP_PORT=8080

# Dominio publico del sitio (lo usa la plantilla de nginx).
APP_DOMAIN=localhost

# Base de datos PostgreSQL (usa contraseñas fuertes en produccion).
DB_DATABASE=redprint
DB_USERNAME=redprint
DB_PASSWORD=secret
DB_PORT=5432
